<UserControl x:Class="WheatGrainClassifierWpfApp.Views.CalculationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WheatGrainClassifierWpfApp.Views"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Gauche -->
        <Grid Background="white" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TRAIN -->
            <Grid Grid.Row="0" Background="white"  Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel   Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="Database" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#1F6FEB"/>
                    <TextBlock Text="Données d’apprentissage (train)" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding LoadTrainCommand}" Padding="14,6"
                    Margin="10,0,0,0"
                    VerticalAlignment="Top"
                    BorderThickness="1.5"
                    BorderBrush="#3B82F6"
                    Foreground="#3B82F6"
                    Background="Transparent"
                    Cursor="Hand">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Folder Icon -->
                        <iconPacks:PackIconMaterial Kind="FolderUpload"
                                        Width="16"
                                        Height="16"
                                        Margin="0,0,6,0"
                                        Foreground="#3B82F6"/>

                        <TextBlock Text="Charger Train"
                       VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
            

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding TrainData}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Label"     Binding="{Binding Variety}"       Width="*"/>
                    <DataGridTextColumn Header="Surface"    Binding="{Binding Area}"        Width="*"/>
                    <DataGridTextColumn Header="Périmètre"  Binding="{Binding Perimeter}"   Width="*"/>
                    <DataGridTextColumn Header="Compacité"  Binding="{Binding Compactness}" Width="*"/>
                    <DataGridTextColumn Header="Longueur"   Binding="{Binding Kernel_Length}" Width="*"/>
                    <DataGridTextColumn Header="Largeur"    Binding="{Binding Kernel_Width}" Width="*"/>
                    <DataGridTextColumn Header="Asymétrie"  Binding="{Binding Asymmetry_Coefficient}" Width="*"/>
                    <DataGridTextColumn Header="Sillon"     Binding="{Binding Kernel_GrooveLength}" Width="*"/>
                </DataGrid.Columns>

            </DataGrid>

            <!-- TEST -->
            <Grid Grid.Row="2" Background="white"  Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel   Orientation="Horizontal" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="Database" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#1F6FEB"/>
                    <TextBlock Text="Données de test" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding LoadTestCommand}" Padding="14,6"
                    Margin="10,0,0,0"
                    VerticalAlignment="Top"
                    BorderThickness="1.5"
                    BorderBrush="#3B82F6"
                    Foreground="#3B82F6"
                    Background="Transparent"
                    Cursor="Hand">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Folder Icon -->
                        <iconPacks:PackIconMaterial Kind="FolderUpload"
                            Width="16"
                            Height="16"
                            Margin="0,0,6,0"
                            Foreground="#3B82F6"/>

                        <TextBlock Text="Charger Test" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <DataGrid Grid.Row="3"
                      ItemsSource="{Binding TestData}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Label"     Binding="{Binding Variety}"       Width="*"/>
                    <DataGridTextColumn Header="Surface"    Binding="{Binding Area}"        Width="*"/>
                    <DataGridTextColumn Header="Périmètre"  Binding="{Binding Perimeter}"   Width="*"/>
                    <DataGridTextColumn Header="Compacité"  Binding="{Binding Compactness}" Width="*"/>
                    <DataGridTextColumn Header="Longueur"   Binding="{Binding Kernel_Length}" Width="*"/>
                    <DataGridTextColumn Header="Largeur"    Binding="{Binding Kernel_Width}" Width="*"/>
                    <DataGridTextColumn Header="Asymétrie"  Binding="{Binding Asymmetry_Coefficient}" Width="*"/>
                    <DataGridTextColumn Header="Sillon"     Binding="{Binding Kernel_GrooveLength}" Width="*"/>
                </DataGrid.Columns>

            </DataGrid>
        </Grid>
        
        <!-- Droit -->
        <StackPanel Background="white" Grid.Column="1" Margin="15">

            <TextBlock Text="Configuration" FontWeight="Bold" FontSize="16"/>

            <TextBlock Text="k"/>
            <TextBox Text="{Binding K}" Margin="0,5"/>

            <TextBlock Text="Distance"/>
            <ComboBox ItemsSource="{Binding Distances}"
                      SelectedItem="{Binding SelectedDistance}" Margin="0,5"/>

            <Button Content="Run Classification"
                    Command="{Binding RunCommand}"
                    Margin="0,10"/>

            <TextBlock Text="Accuracy :" FontWeight="Bold"/>
            <TextBlock Text="{Binding Accuracy}"/>

            <TextBlock Text="Confusion Matrix" Margin="10,10,0,5"/>

            <DataGrid ItemsSource="{Binding ConfusionMatrix}"
                      AutoGenerateColumns="True"
                      Height="200"/>
        </StackPanel>
    </Grid>
</UserControl>
