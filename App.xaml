<Application x:Class="WheatGrainClassifierWpfApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WheatGrainClassifierWpfApp"
             xmlns:views="clr-namespace:WheatGrainClassifierWpfApp.Views"
             xmlns:viewModels="clr-namespace:WheatGrainClassifierWpfApp.ViewModels"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <DataTemplate DataType="{x:Type viewModels:CalculationViewModel}">
            <views:CalculationView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ExperienceViewModel}">
            <views:ExperienceView />
        </DataTemplate>
    </Application.Resources>
</Application>
